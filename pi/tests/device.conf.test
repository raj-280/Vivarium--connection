# =============================================================================
# pi/tests/device.conf.test — Stage 7 socat test configuration.
#
# DO NOT USE ON A REAL PI — this file has blank credentials and a virtual
# serial port that only exists when socat is running.
#
# Usage:
#   1. Run socat and note the two port paths it prints (see fake_arduino.py).
#   2. Copy this file to /tmp/device.conf.test.
#   3. Edit serial_port below to the FIRST port socat printed (bridge's end).
#   4. export GANTRY_DEVICE_CONF=/tmp/device.conf.test
#   5. Run bridge.py in one terminal, fake_arduino.py in another.
# =============================================================================

[identity]
device_id = rack-test
cpu_serial =

[server]
server_host = http://localhost:8000
presign_api_key =
mqtt_password =
rtsp_password =

[mqtt]
broker_host = localhost
broker_port = 1883
mqtt_use_tls = false
ca_cert_path =

[serial]
# ↓ Replace with the FIRST port socat prints (e.g. /dev/pts/3).
# fake_arduino.py gets the SECOND port (e.g. /dev/pts/4).
serial_port = /dev/pts/3
serial_baud = 115200
# Keep timeout short during testing so SERIAL_TIMEOUT is fast to observe.
serial_timeout_s = 3
serial_retry_count = 1

[capture]
capture_dir = /tmp/vivarium-test-captures
batch_upload_enabled = false
tmp_is_tmpfs = false

[streaming]
go2rtc_port = 8554
go2rtc_stream_name = rack-test

[scan]
scan_lock_keepalive_interval_s = 30
