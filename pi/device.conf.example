# =============================================================================
# Vivarium Gantry System — Pi device configuration (Section 2.2)
# =============================================================================
# Real path: /etc/vivarium/device.conf, mode 600 (owner pi:pi).
# Written automatically by pi/provisioner.py on first boot (Section 5.3) —
# you should not normally need to hand-edit this file on a real Pi.
#
# ── Local testing ────────────────────────────────────────────────────────
# pi/config/settings.py ALWAYS reads /etc/vivarium/device.conf.
# To test on a dev machine, create the file there:
#
#     sudo mkdir -p /etc/vivarium
#     sudo cp pi/device.conf.example /etc/vivarium/device.conf
#     sudo chmod 600 /etc/vivarium/device.conf
#     sudo chown $USER /etc/vivarium/device.conf
#
# NOTE: GANTRY_DEVICE_CONF env var is NOT supported — settings.py hard-codes
# /etc/vivarium/device.conf. Pass conf_path= in unit tests instead.
# =============================================================================

[identity]
# This Pi's logical rack ID, e.g. rack-047. Assigned by /provision
# (Section 4.6 / 5.3).
device_id = rack-test

# CPU serial is read from /proc/cpuinfo during provisioning and is NOT
# stored here after provisioning completes (Section 2.2) — left blank.
cpu_serial =

[server]
# Base URL of the FastAPI server (used by provisioner.py and, later,
# camera_handler.py for /presign — Section 5.3 / 5.4).
server_host = http://localhost:8000

# Credentials issued by POST /provision (Section 4.6 / 5.3).
presign_api_key =
mqtt_password =
rtsp_password =

[mqtt]
# Mirrors the server's MQTT_BROKER / MQTT_PORT (Section 2.1).
# Written by provisioner.py from env var GANTRY_MQTT_BROKER (set by setup.sh).
broker_host = localhost
broker_port = 1883

# [PROD ONLY] — inert locally (Section 9).
mqtt_use_tls = false
ca_cert_path =

[serial]
# Arduino link configuration (Section 2.2 / 6).
# "auto" → SerialHandler scans /dev/ttyACM* and /dev/ttyUSB* and picks the
# first Arduino it finds.  Pin to a fixed port (e.g. /dev/ttyACM0) only if
# you have multiple serial devices.
# Matches: settings.py _DEFAULTS["serial"]["serial_port"] and
#          provisioner.py _write_device_conf() serial_port value.
serial_port = auto
serial_baud = 115200
# 10 s: enough headroom for slow firmware responses without hanging forever.
# Matches: settings.py _DEFAULTS["serial"]["serial_timeout_s"] = "10"
#          provisioner.py _write_device_conf() serial_timeout_s value.
serial_timeout_s = 10
serial_retry_count = 1

[capture]
# On a real Pi, provisioner.py writes the absolute path:
#   /var/vivarium/{device_id}/captures
# which setup.sh pre-creates (mode 750, owner pi:pi).
# For local dev/testing without a real Pi, use a relative path:
#   ./captures
# Matches: provisioner.py _write_device_conf() capture_dir value (real Pi).
#          settings.py _DEFAULTS["capture"]["capture_dir"] (dev fallback).
capture_dir = /var/vivarium/rack-test/captures

batch_upload_enabled = false

# true on a real Pi (/tmp is RAM-backed tmpfs). false for local dev/testing
# where /tmp is a normal disk-backed directory.
tmp_is_tmpfs = false

[streaming]
# MediaMTX RTSP port (Section 5.6).
# Matches: provisioner.py _MEDIAMTX_DEFAULT_PORT = "8554"
#          mediamtx/mediamtx.example.yaml  rtspAddress: ":{{MEDIAMTX_PORT}}"
mediamtx_port = 8554
# stream_name MUST match device_id — the server builds the RTSP URL from it
# (Section 8).  provisioner.py always sets this to the assigned device_id.
stream_name = rack-test

[scan]
# How often the Pi pings the server to extend a scan lock (Section 4.3 / 4.7).
scan_lock_keepalive_interval_s = 30
