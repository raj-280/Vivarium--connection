# =============================================================================
# Vivarium Gantry System — server environment variables
# Copy this file to .env and fill in real values before deploying.
# Local-dev defaults are shown; they work without a .env file at all.
# =============================================================================

# --- MQTT (Section 2.1) ------------------------------------------------------
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_USE_TLS=false              # [PROD ONLY] set true, supply MQTT_TLS_CA_PATH
MQTT_TLS_CA_PATH=               # [PROD ONLY] /etc/mosquitto/certs/ca.crt

# --- Server (Section 2.1) ----------------------------------------------------
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Auth (Section 2.1) ------------------------------------------------------
# IMPORTANT: change ALL three values before any non-local deployment.
ADMIN_TOKEN=dev-admin-token-change-in-production
PI_API_KEY=dev-pi-api-key-change-in-production
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production-min-32-chars
JWT_EXPIRE_MINUTES=60
CSRF_ENABLED=false              # can be true locally (non-Secure cookie)
COOKIE_SECURE=false             # [PROD ONLY] true requires HTTPS

# --- Provisioning (Section 2.1) ----------------------------------------------
PROVISIONING_SECRET=dev-provisioning-secret
PROVISION_TOKEN_TTL_HOURS=24

# --- Database (Section 2.1) --------------------------------------------------
DATABASE_URL=sqlite:///./vivarium.db
# PostgreSQL (production): DATABASE_URL=postgresql://user:pass@host:5432/vivarium

# --- Cache / Rate-limit (Section 2.1) ----------------------------------------
CACHE_BACKEND=sqlite            # sqlite | redis
REDIS_URL=redis://localhost:6379/0   # only used when CACHE_BACKEND=redis

# --- S3 (Section 2.1 / 12) ---------------------------------------------------
# S3_ENABLED=false → images written to LOCAL_IMAGE_DIR; no code changes needed
# to flip to S3 later (Section 12).
S3_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
S3_ENDPOINT_URL=                # blank = real AWS; MinIO URL = local S3 testing
LOCAL_IMAGE_DIR=./images

# --- Timeouts (Section 2.1, all in seconds) ----------------------------------
COMMAND_TIMEOUT_S=10
MOTION_TIMEOUT_S=30
HOMING_TIMEOUT_S=60
CAPTURE_LOCK_TIMEOUT_S=120
MANUAL_VS_SCAN_RESUME_WINDOW_S=300

# --- Rack geometry defaults (Section 2.1) ------------------------------------
RACK_ROWS=12
RACK_COLS=7
X0_OFFSET_MM=0.0
PITCH_X_MM=50.0
Y0_OFFSET_MM=0.0
PITCH_Y_MM=50.0
POSITION_TOLERANCE_X_MM=3.0
POSITION_TOLERANCE_Y_MM=2.0

# --- Streaming (Section 2.1 / 8) ---------------------------------------------
# The browser connects DIRECTLY to the Pi's MediaMTX for video (no server proxy).
# Both values below must be the Pi's LAN IP/hostname — reachable from the browser.
#
# MEDIAMTX_PI_HOST    → used to build WebRTC/MJPEG URLs sent to the browser
# MEDIAMTX_INTERNAL_URL → used by the server to probe MediaMTX health (port 9997)
#
# Example (Pi at 192.168.1.50):
#   MEDIAMTX_PI_HOST=192.168.1.50
#   MEDIAMTX_INTERNAL_URL=http://192.168.1.50:9997
MEDIAMTX_PI_HOST=              # e.g. 192.168.1.50  (Pi's LAN IP)
MEDIAMTX_INTERNAL_URL=         # e.g. http://192.168.1.50:9997
MEDIAMTX_WEBRTC_PORT=8889      # MediaMTX WebRTC (WHEP) port — default 8889
MEDIAMTX_MJPEG_PORT=8888       # MediaMTX HLS/MJPEG port — default 8888
STREAM_URL_TTL_S=3600

# --- Scan engine (Section 2.1) ------------------------------------------------
SCAN_POSTPONE_MINUTES=15
SCAN_STAGGER_GROUP_SIZE=5
SCAN_STAGGER_DELAY_MINUTES=2

# --- Production toggles (Section 2.1 / 9) ------------------------------------
# All false/empty locally. Flipping these IS the production hardening pass
# (Stage 15 of Section 13). Do NOT set to true without completing that pass.
TLS_ENABLED=false               # [PROD ONLY]
HSTS_ENABLED=false              # [PROD ONLY]
CSP_ENABLED=false               # [PROD ONLY]
WIREGUARD_REQUIRED=false        # [PROD ONLY]
ANSIBLE_INVENTORY_PATH=         # [PROD ONLY] path to Ansible inventory file
